#!/usr/bin/env python3
"""Debug script: prints raw goals data from API for the latest finished match."""
import json, os, sys
from urllib.request import urlopen, Request

BASE_URL = "https://api.football-data.org/v4"
MAN_CITY_TEAM_ID = 65

api_key = os.environ.get("FOOTBALL_DATA_KEY") or (sys.argv[1] if len(sys.argv) > 1 else "")
if not api_key:
    print("Usage: python debug_api.py YOUR_API_KEY")
    sys.exit(1)

def fetch(url):
    with urlopen(Request(url, headers={"X-Auth-Token": api_key}), timeout=15) as res:
        return json.loads(res.read().decode())

data = fetch(f"{BASE_URL}/teams/{MAN_CITY_TEAM_ID}/matches?status=FINISHED")
matches = data.get("matches", [])
if not matches:
    print("No finished matches found")
    sys.exit(1)

m = matches[-1]
match_id = m["id"]
home = (m.get("homeTeam") or {}).get("name", "?")
away = (m.get("awayTeam") or {}).get("name", "?")
print(f"Match: {home} vs {away}  (ID: {match_id})")

detail = fetch(f"{BASE_URL}/matches/{match_id}")
print(f"Top-level keys: {list(detail.keys())}")
goals = detail.get("goals")
print(f"goals field:\n{json.dumps(goals, indent=2)}")
